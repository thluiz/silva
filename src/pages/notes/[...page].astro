---
import { type CollectionEntry, getCollection } from "astro:content";
import type { GetStaticPaths, Page } from "astro";
import { Icon } from "astro-icon/components";
import Note from "@/components/note/Note.astro";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

export const getStaticPaths = (async ({ paginate }) => {
	const allNotes = await getCollection("note");
	return paginate(allNotes.sort(collectionDateSort), { pageSize: 100 });
}) satisfies GetStaticPaths;

interface Props {
	page: Page<CollectionEntry<"note">>;
}

const { page } = Astro.props;

const meta = {
	description: "Notas breves, referências e pensamentos rápidos.",
	title: "Notas",
};

// Group notes by tag — notes with no tags go under "sem tag"
const tagged: Record<string, CollectionEntry<"note">[]> = {};
const untagged: CollectionEntry<"note">[] = [];

for (const note of page.data) {
	const tags = note.data.tags ?? [];
	if (tags.length === 0) {
		untagged.push(note);
	} else {
		for (const tag of tags) {
			if (!tagged[tag]) tagged[tag] = [];
			tagged[tag].push(note);
		}
	}
}

const sortedTags = Object.keys(tagged).sort();
---

<PageLayout meta={meta}>
	<section>
		<h1 class="title mb-12 flex items-center gap-3">
			Notas <a class="text-accent" href="/notes/rss.xml" target="_blank">
				<span class="sr-only">RSS feed</span>
				<Icon aria-hidden="true" class="h-6 w-6" focusable="false" name="mdi:rss" />
			</a>
		</h1>

		{sortedTags.map((tag) => (
			<section class="mb-12">
				<h2 class="title text-accent mb-6 text-lg capitalize">#{tag}</h2>
				<ul class="space-y-6">
					{tagged[tag]!.map((note) => (
						<li>
							<Note note={note} as="h3" isPreview />
						</li>
					))}
				</ul>
			</section>
		))}

		{untagged.length > 0 && (
			<section class="mb-12">
				<h2 class="title text-accent mb-6 text-lg">Sem tag</h2>
				<ul class="space-y-6">
					{untagged.map((note) => (
						<li>
							<Note note={note} as="h3" isPreview />
						</li>
					))}
				</ul>
			</section>
		)}
	</section>
</PageLayout>
