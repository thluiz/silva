---
import { type CollectionEntry, getCollection } from "astro:content";
import type { GetStaticPaths, Page } from "astro";
import { Icon } from "astro-icon/components";
import Note from "@/components/note/Note.astro";
import Pagination from "@/components/Paginator.astro";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

export const getStaticPaths = (async ({ paginate }) => {
	const allNotes = await getCollection("note");
	const sorted = allNotes.sort(collectionDateSort);

	const uniqueTags = [...new Set(sorted.flatMap((n) => n.data.tags ?? []))];

	return uniqueTags.flatMap((tag) => {
		const notesWithTag = sorted.filter((n) => (n.data.tags ?? []).includes(tag));
		return paginate(notesWithTag, { pageSize: 10, params: { tag } });
	});
}) satisfies GetStaticPaths;

interface Props {
	page: Page<CollectionEntry<"note">>;
}

const { page } = Astro.props;
const { tag } = Astro.params;

const meta = {
	description: `Notas com a tag #${tag}`,
	title: `#${tag} — Notas`,
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: { text: "← Página anterior", url: page.url.prev },
	}),
	...(page.url.next && {
		nextUrl: { text: "Próxima página →", url: page.url.next },
	}),
};
---

<PageLayout meta={meta}>
	<nav class="mb-8" aria-label="Breadcrumbs">
		<ul class="flex items-center gap-1.5">
			<li><a class="text-accent" href="/notes/">Notas</a></li>
			<li>›</li>
			<li><a class="text-accent" href="/notes/tags/">Tags</a></li>
			<li>›</li>
			<li aria-current="page"><span aria-hidden="true">#</span>{tag}</li>
		</ul>
	</nav>
	<h1 class="title mb-12 capitalize">#{tag}</h1>
	<ul class="space-y-8">
		{
			page.data.map((note) => (
				<li>
					<Note note={note} as="h2" isPreview />
				</li>
			))
		}
	</ul>
	<Pagination {...paginationProps} />
</PageLayout>
