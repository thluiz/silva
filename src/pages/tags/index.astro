---
import { getAllPosts, getUniqueTagsWithCount } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";

const allPosts = await getAllPosts();
const allTags = getUniqueTagsWithCount(allPosts);

const meta = {
	description: "Todos os temas abordados nos textos.",
	title: "Tags",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-2">Tags</h1>
	<p class="text-muted mb-6 text-sm">{allTags.length} tags</p>
	<ul class="silva-tag-cloud">
		{
			allTags.map(([tag, val]) => (
				<li>
					<a href={`/tags/${tag}/`}>
						<span class="silva-tag-name">#{tag}</span>
						<span class="silva-tag-count">{val}</span>
					</a>
				</li>
			))
		}
	</ul>
</PageLayout>
