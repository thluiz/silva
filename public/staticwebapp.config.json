{
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": [
      "/assets/*",
      "/_astro/*",
      "/pagefind/*",
      "/icons/*",
      "/*.{css,js,png,jpg,jpeg,svg,ico,woff,woff2,ttf,json,xml,txt,webp,avif}"
    ]
  },
  "mimeTypes": {
    ".json": "application/json",
    ".xml": "application/xml"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  }
}
